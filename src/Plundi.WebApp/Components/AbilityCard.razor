<div class="flex flex-col rounded shadow bg-slate-900 border-slate-950">
    <div class="grid px-4 py-2 items-baseline rounded-t shadow grid-cols-[1fr,auto,1fr] gap-2 bg-slate-950 @(DisplayInCompactView ? "rounded-b" : "")">
        <span class="text-xs text-slate-500">
            @(Position).
        </span>
        <span class="col-start-2 text-xs text-center lowercase text-slate-500">
            @Ability.Name
        </span>
        <div class="flex col-start-3 gap-2 justify-end">
            <i class="p-2 text-xs cursor-pointer fa-solid fa-chevron-up text-slate-500 hover:text-slate-100"
               @onclick="async _ => await OnMoveUpClicked.InvokeAsync()">
            </i>
            <i class="p-2 text-xs cursor-pointer fa-solid fa-chevron-down text-slate-500 hover:text-slate-100"
               @onclick="async _ => await OnMoveDownClicked.InvokeAsync()">
            </i>
        </div>
    </div>
    @{
        var damageReport = DamageReportGenerator.GenerateDamageReport(Ability.OriginalAbility, CharacterLevel, Ability.Rarity);
        var cooldown = Ability.GetCooldown(CharacterLevel);

        var minDps = Math.Round(damageReport.DamageRange.Min / cooldown, 1);
        var maxDps = Math.Round(damageReport.DamageRange.Max / cooldown, 1);

        var minHitAndDotDamage = damageReport.HitDamageRange.Min + damageReport.DotDamageRange.Min;
        var maxHitAndDotDamage = damageReport.HitDamageRange.Max + damageReport.DotDamageRange.Max;

        if (DisplayInCompactView)
        {
            <div class="flex flex-row gap-2 items-center p-4 2xl:gap-4 md:max-xl:gap-4">
                <div class="w-24 h-24 bg-clip-border bg-cover rounded border shadow border-slate-950" style="background-image: url('img/abilities/@Ability.ImagePath')">
                </div>
                <div class="grid grid-cols-3 gap-2 items-center 2xl:gap-4 grow md:max-xl:gap-4">
                    <div class="flex flex-col gap-2 items-center">
                        @if (Math.Abs(damageReport.DamageRange.Min - damageReport.DamageRange.Max) < 0.1)
                        {
                            <span class="font-mono text-2xl font-bold 2xl:text-4xl md:max-xl:text-4xl">@Math.Round(damageReport.DamageRange.Max)</span>
                        }
                        else
                        {
                            <span class="font-mono text-2xl font-bold 2xl:text-4xl md:max-xl:text-4xl">@Math.Round(damageReport.DamageRange.Min)-@Math.Round(damageReport.DamageRange.Max)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">potential damage</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center 2xl:col-span-1 md:max-xl:col-span-1">
                        @if (Math.Abs(minDps - maxDps) < 0.1)
                        {
                            <span class="font-mono font-bold 2xl:text-xl md:max-xl:text-xl">@maxDps</span>
                        }
                        else
                        {
                            <span class="font-mono font-bold 2xl:text-xl md:max-xl:text-xl">@minDps-@maxDps</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">potential dps</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center">
                        <span class="font-mono text-center 2xl:text-xl md:max-xl:text-xl">@(cooldown == 0 ? "-" : $"{cooldown}s")</span>
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">cooldown</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="flex flex-col gap-4 items-center p-4 2xl:flex-row md:max-xl:flex-row">
                <div class="w-24 h-24 bg-clip-border bg-cover rounded border shadow border-slate-950" style="background-image: url('img/abilities/@Ability.ImagePath')">
                </div>
                <div class="grid grid-cols-3 gap-2 items-center 2xl:grid-cols-4 2xl:gap-4 grow md:max-xl:grid-cols-4 md:max-xl:gap-4">
                    <div class="flex flex-col col-span-3 gap-2 items-center 2xl:col-span-1 md:max-xl:col-span-1">
                        @if (Math.Abs(damageReport.DamageRange.Min - damageReport.DamageRange.Max) < 0.1)
                        {
                            <span class="font-mono text-2xl font-bold 2xl:text-4xl md:max-xl:text-4xl">@Math.Round(damageReport.DamageRange.Max)</span>
                        }
                        else
                        {
                            <span class="font-mono text-2xl font-bold 2xl:text-4xl md:max-xl:text-4xl">@Math.Round(damageReport.DamageRange.Min)-@Math.Round(damageReport.DamageRange.Max)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">potential damage</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center 2xl:col-span-1 md:max-xl:col-span-1">
                        @if (Math.Abs(minDps - maxDps) < 0.1)
                        {
                            <span class="font-mono font-bold 2xl:text-xl md:max-xl:text-xl">@maxDps</span>
                        }
                        else
                        {
                            <span class="font-mono font-bold 2xl:text-xl md:max-xl:text-xl">@minDps-@maxDps</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">potential dps</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center">
                        @if (Math.Abs(minHitAndDotDamage - maxHitAndDotDamage) < 0.1)
                        {
                            <span class="font-mono 2xl:text-xl md:max-xl:text-xl">@Math.Round(maxHitAndDotDamage)</span>
                        }
                        else
                        {
                            <span class="font-mono 2xl:text-xl md:max-xl:text-xl">@Math.Round(minHitAndDotDamage)-@Math.Round(maxHitAndDotDamage)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">hit & dot damage</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center">
                        @if (Math.Abs(damageReport.SpecialDamageRange.Min - damageReport.SpecialDamageRange.Max) < 0.1)
                        {
                            <span class="font-mono 2xl:text-xl md:max-xl:text-xl">@Math.Round(damageReport.SpecialDamageRange.Max)</span>
                        }
                        else
                        {
                            <span class="font-mono 2xl:text-xl md:max-xl:text-xl">@Math.Round(damageReport.SpecialDamageRange.Min)-@Math.Round(damageReport.SpecialDamageRange.Max)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">special damage</span>
                    </div>
                </div>
            </div>
            <hr class="border-slate-950"/>
            <div class="grid grid-cols-3 gap-2 items-center p-4">
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center 2xl:text-xl md:max-xl:text-xl">@(cooldown == 0 ? "-" : $"{cooldown}s")</span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">cooldown</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center 2xl:text-xl md:max-xl:text-xl">@(Ability.CastDuration == 0 ? "-" : $"{Ability.CastDuration}s")</span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">cast duration</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center 2xl:text-xl md:max-xl:text-xl">@(Ability.ChannelDuration == 0 ? "-" : $"{Ability.ChannelDuration}s")</span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">channel duration</span>
                </div>
            </div>
            <hr class="border-slate-950"/>
            <div class="grid grid-cols-3 gap-2 items-center p-4">
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">
                        @if (damageReport.DefaultHits.Count == 0)
                        {
                            @: -
                        }
                        else
                        {
                            @DamageSequenceToReadableString(damageReport.DefaultHits)
                        }
                    </span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">hit dmg profile</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">
                        @if (damageReport.SpecialHits.Count == 0)
                        {
                            @: -
                        }
                        else
                        {
                            @DamageSequenceToReadableString(damageReport.SpecialHits)
                        }
                    </span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">special dmg profile</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">
                        @if (damageReport.DotHits.Count == 0)
                        {
                            @: -
                        }
                        else
                        {
                            @DamageSequenceToReadableString(damageReport.DotHits)
                        }
                    </span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">dot dmg profile</span>
                </div>
            </div>
            <hr class="border-slate-950"/>
            <div class="flex flex-wrap gap-4 justify-center items-start p-4 grow">
                @foreach (var effect in Ability.GetEffects(CharacterLevel))
                {
                    if (effect.Duration == 0)
                    {
                        <div class="py-1 px-2 font-mono rounded shadow bg-slate-950">
                            <span class="text-xs text-center">@effect.Description</span>
                        </div>
                    }
                    else
                    {
                        <div class="flex shadow">
                            <div class="py-1 px-2 rounded-l bg-slate-950">
                                <span class="font-mono text-xs text-center">@effect.Description</span>
                            </div>
                            <div class="py-1 px-2 rounded-r border-l border-slate-900 bg-slate-950">
                                <span class="font-mono text-xs text-center text-slate-500">@(effect.Duration)s</span>
                            </div>
                        </div>
                    }
                }
            </div>
        }

        <div class="grid grid-cols-4 rounded-b">
            <button class="py-1 px-2 h-8 text-xs rounded-bl border-t focus:outline-none border-slate-950 @(Ability.Rarity == AbilityRarity.Common ? "font-bold text-slate-900 bg-slate-500 hover:bg-slate-400" : "text-slate-100 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Common">
                Common
            </button>
            <button class="py-1 px-2 h-8 text-xs border-t border-l focus:outline-none border-slate-950 @(Ability.Rarity == AbilityRarity.Uncommon ? "font-bold text-slate-900 bg-emerald-700 hover:bg-emerald-600" : "text-emerald-500 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Uncommon">
                Uncommon
            </button>
            <button class="py-1 px-2 h-8 text-xs border-t border-l focus:outline-none border-slate-950 @(Ability.Rarity == AbilityRarity.Rare ? "font-bold text-slate-900 bg-sky-700 hover:bg-sky-600" : "text-sky-500 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Rare">
                Rare
            </button>
            <button class="py-1 px-2 h-8 text-xs rounded-br border-t border-l focus:outline-none border-slate-950 @(Ability.Rarity == AbilityRarity.Epic ? "font-bold text-slate-900 bg-purple-700 hover:bg-purple-600" : "text-purple-500 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Epic">
                Epic
            </button>
        </div>
    }
</div>