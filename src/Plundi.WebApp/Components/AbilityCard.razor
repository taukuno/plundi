<div class="flex flex-col rounded border shadow bg-slate-900 border-slate-950">
    <div class="grid py-2 px-4 items-baseline rounded-t shadow grid-cols-[1fr,auto,1fr] gap-2 bg-slate-950">
        <span class="text-xs text-slate-500">
            @(Position).
        </span>
        <span class="col-start-2 text-xs text-center text-slate-500">
            @Ability.Name
        </span>
        <div class="flex col-start-3 gap-2 justify-end">
            <i class="p-2 -my-2 text-xs cursor-pointer fa-solid fa-chevron-up text-slate-500 hover:text-slate-100"
               @onclick="async _ => await OnMoveUpClicked.InvokeAsync()">
            </i>
            <i class="p-2 -my-2 -mr-2 text-xs cursor-pointer fa-solid fa-chevron-down text-slate-500 hover:text-slate-100"
               @onclick="async _ => await OnMoveDownClicked.InvokeAsync()">
            </i>
        </div>
    </div>
    @{
        var damageReport = AbilityReportGenerator.GenerateDamageReport(Ability.OriginalAbility, CharacterLevel, Ability.Rarity);

        var cooldown = Ability.GetCooldown(CharacterLevel);
        var minHitAndDotDamage = damageReport.BaseDamageRange.Min + damageReport.DotDamageRange.Min;
        var maxHitAndDotDamage = damageReport.BaseDamageRange.Max + damageReport.DotDamageRange.Max;

        var damageTextColor = Ability.Rarity switch
        {
            AbilityRarity.Common => "text-white",
            AbilityRarity.Uncommon => "text-emerald-400",
            AbilityRarity.Rare => "text-sky-400",
            AbilityRarity.Epic => "text-purple-400",
            _ => "text-white"
        };

        if (DisplayInCompactView)
        {
            <div class="flex flex-row gap-2 items-center py-2 px-4 2xl:gap-4 md:max-lg:gap-4">
                <div class="w-14 h-14 bg-clip-border bg-cover rounded border shadow border-slate-950" style="background-image: url('img/abilities/@Ability.ImagePath')">
                </div>
                <div class="grid grid-cols-3 gap-2 items-center 2xl:gap-4 grow md:max-lg:gap-4">
                    <div class="flex flex-col items-center">
                        @if (Math.Abs(damageReport.TotalDamageRange.Min - damageReport.TotalDamageRange.Max) < 0.1)
                        {
                            <span class="font-mono font-bold sm:text-xl text-center @damageTextColor">@Math.Round(damageReport.TotalDamageRange.Max)</span>
                        }
                        else
                        {
                            <span class="font-mono font-bold sm:text-xl text-center @damageTextColor">@Math.Round(damageReport.TotalDamageRange.Min)-@Math.Round(damageReport.TotalDamageRange.Max)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">damage</span>
                    </div>
                    <div class="flex flex-col items-center">
                        @if (Math.Abs(damageReport.TotalDamageRange.MinDps - damageReport.TotalDamageRange.MaxDps) < 0.1)
                        {
                            <span class="font-mono text-center sm:text-xl">@Math.Round(damageReport.TotalDamageRange.MaxDps, 1)</span>
                        }
                        else
                        {
                            <span class="font-mono text-center sm:text-xl">@Math.Round(damageReport.TotalDamageRange.MinDps, 1)-@Math.Round(damageReport.TotalDamageRange.MaxDps, 1)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">dps</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="font-mono text-center sm:text-xl">@(cooldown == 0 ? "-" : $"{cooldown}s")</span>
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">cooldown</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="flex flex-row gap-4 items-center p-4">
                <div class="w-20 h-20 bg-clip-border bg-cover rounded border shadow border-slate-950" style="background-image: url('img/abilities/@Ability.ImagePath')">
                </div>
                <div class="grid grid-cols-2 gap-x-2 gap-y-4 items-center 2xl:grid-cols-4 2xl:gap-4 grow md:max-lg:grid-cols-4 md:max-lg:gap-x-4">
                    <div class="flex flex-col gap-1 items-center xl:order-1 md:max-lg:order-1">
                        @if (Math.Abs(damageReport.TotalDamageRange.Min - damageReport.TotalDamageRange.Max) < 0.1)
                        {
                            <span class="font-mono text-xl sm:text-2xl text-center font-bold @damageTextColor">@Math.Round(damageReport.TotalDamageRange.Max)</span>
                        }
                        else
                        {
                            <span class="font-mono text-xl sm:text-2xl text-center font-bold @damageTextColor">@Math.Round(damageReport.TotalDamageRange.Min)-@Math.Round(damageReport.TotalDamageRange.Max)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">damage</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center 2xl:order-3 md:max-lg:order-3">
                        @if (Math.Abs(minHitAndDotDamage - maxHitAndDotDamage) < 0.1)
                        {
                            <span class="font-mono text-xl text-center sm:text-2xl">@Math.Round(maxHitAndDotDamage)</span>
                        }
                        else
                        {
                            <span class="font-mono text-xl text-center sm:text-2xl">@Math.Round(minHitAndDotDamage)-@Math.Round(maxHitAndDotDamage)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">hit & dot dmg</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center 2xl:order-2 md:max-lg:order-2">
                        @if (Math.Abs(damageReport.TotalDamageRange.MinDps - damageReport.TotalDamageRange.MaxDps) < 0.1)
                        {
                            <span class="font-mono text-xl text-center sm:text-2xl">@Math.Round(damageReport.TotalDamageRange.MaxDps, 1)</span>
                        }
                        else
                        {
                            <span class="font-mono text-xl text-center sm:text-2xl">@Math.Round(damageReport.TotalDamageRange.MinDps, 1)-@Math.Round(damageReport.TotalDamageRange.MaxDps, 1)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">dps</span>
                    </div>
                    <div class="flex flex-col gap-1 items-center xl:order-4 md:max-lg:order-4">
                        @if (Math.Abs(damageReport.SpecialDamageRange.Min - damageReport.SpecialDamageRange.Max) < 0.1)
                        {
                            <span class="font-mono text-xl text-center sm:text-2xl">@Math.Round(damageReport.SpecialDamageRange.Max)</span>
                        }
                        else
                        {
                            <span class="font-mono text-xl text-center sm:text-2xl">@Math.Round(damageReport.SpecialDamageRange.Min)-@Math.Round(damageReport.SpecialDamageRange.Max)</span>
                        }
                        <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">special dmg</span>
                    </div>
                </div>
            </div>
            <hr class="border-slate-950"/>
            <div class="grid grid-cols-3 gap-2 items-center p-4">
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">@(cooldown == 0 ? "-" : $"{cooldown}s")</span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">cooldown</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">@(Ability.CastDuration == 0 ? "-" : $"{Ability.CastDuration}s")</span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">cast duration</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">@(Ability.ChannelDuration == 0 ? "-" : $"{Ability.ChannelDuration}s")</span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">channel duration</span>
                </div>
            </div>
            <hr class="border-slate-950"/>
            <div class="grid grid-cols-3 gap-2 items-center p-4">
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">
                        @if (damageReport.BaseHits.Count == 0)
                        {
                            @: -
                        }
                        else
                        {
                            @DamageSequenceToReadableString(damageReport.BaseHits.Select(x => x.Damage).ToList())
                        }
                    </span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">hit dmg profile</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">
                        @if (damageReport.SpecialHits.Count == 0)
                        {
                            @: -
                        }
                        else
                        {
                            @DamageSequenceToReadableString(damageReport.SpecialHits.Select(x => x.Damage).ToList())
                        }
                    </span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">special dmg profile</span>
                </div>
                <div class="flex flex-col gap-1 items-center">
                    <span class="font-mono text-center">
                        @if (damageReport.DotHits.Count == 0)
                        {
                            @: -
                        }
                        else
                        {
                            @DamageSequenceToReadableString(damageReport.DotHits.Select(x => x.Damage).ToList())
                        }
                    </span>
                    <span class="overflow-hidden text-xs whitespace-nowrap text-slate-500">dot dmg profile</span>
                </div>
            </div>
            <hr class="border-slate-950"/>
            <div class="flex flex-wrap gap-4 justify-center items-start p-4 grow">
                @foreach (var effect in Ability.GetEffects(CharacterLevel))
                {
                    if (effect.Duration == 0)
                    {
                        <div class="py-1 px-2 font-mono rounded shadow bg-slate-950">
                            <span class="text-xs text-center">@effect.Description</span>
                        </div>
                    }
                    else
                    {
                        <div class="flex shadow">
                            <div class="py-1 px-2 rounded-l bg-slate-950">
                                <span class="font-mono text-xs text-center">@effect.Description</span>
                            </div>
                            <div class="py-1 px-2 rounded-r border-l border-slate-900 bg-slate-950">
                                <span class="font-mono text-xs text-center text-slate-500">@(effect.Duration)s</span>
                            </div>
                        </div>
                    }
                }
            </div>
        }

        var buttonVerticalPadding = DisplayInCompactView ? "py-1" : "py-2";

        <div class="grid grid-cols-4 rounded-b">
            <button class="@buttonVerticalPadding px-2 text-xs rounded-bl border-t border-slate-950 @(Ability.Rarity == AbilityRarity.Common ? "font-bold text-slate-900 bg-slate-500 hover:bg-slate-400" : "text-white hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Common">
                Common
            </button>
            <button class="@buttonVerticalPadding px-2 text-xs border-t border-l border-slate-950 @(Ability.Rarity == AbilityRarity.Uncommon ? "font-bold text-slate-900 bg-emerald-600 hover:bg-emerald-500" : "text-emerald-400 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Uncommon">
                Uncommon
            </button>
            <button class="@buttonVerticalPadding px-2 text-xs border-t border-l border-slate-950 @(Ability.Rarity == AbilityRarity.Rare ? "font-bold text-slate-900 bg-sky-600 hover:bg-sky-500" : "text-sky-400 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Rare">
                Rare
            </button>
            <button class="@buttonVerticalPadding px-2 text-xs rounded-br border-t border-l border-slate-950 @(Ability.Rarity == AbilityRarity.Epic ? "font-bold text-slate-900 bg-purple-600 hover:bg-purple-500" : "text-purple-400 hover:bg-slate-950")"
                    @onclick="() => Ability.Rarity = AbilityRarity.Epic">
                Epic
            </button>
        </div>
    }
</div>